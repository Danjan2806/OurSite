# PostgreSQL password
DB_PASSWORD=postgres

# JWT secret — CHANGE THIS IN PRODUCTION
SESSION_SECRET=saas-builder-dev-secret-key-2024-change-in-prod

# API URL the React frontend uses to call the backend
# Must be reachable from the user's browser (not the Docker internal network)
VITE_API_URL=http://localhost:8080

# OpenAI API key — required for the "Create from screenshot" AI feature
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
